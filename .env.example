# =============================================================================
# VoiceIQ Insight Service – environment configuration
# Copy this file to `.env` and edit the values you want to override.
# Every key is OPTIONAL: the service ships with safe defaults.
# Keys are read with the prefix VOICEIQ_  (handled by InsightSettings).
# =============================================================================

# ---- Service metadata -------------------------------------------------------
VOICEIQ_SERVICE_NAME="VoiceIQ Insight Service"
VOICEIQ_SERVICE_VERSION=1.0.0
# One of: development | staging | production | test
VOICEIQ_ENVIRONMENT=development
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
VOICEIQ_LOG_LEVEL=INFO

# ---- Persistence ------------------------------------------------------------
# SQLAlchemy URL. Defaults to a local SQLite file under ./data/insights.db.
# Examples:
#   sqlite:///./data/insights.db
#   sqlite:////absolute/path/insights.db
#   postgresql+psycopg://user:pass@localhost:5432/voiceiq
VOICEIQ_DATABASE_URL=sqlite:///./data/insights.db
# Set to true only for SQL debugging — very chatty.
VOICEIQ_DATABASE_ECHO=false
# Auto-create tables on startup. Disable in environments managed by migrations.
VOICEIQ_DATABASE_AUTO_CREATE=true

# ---- Engine configuration --------------------------------------------------
# Named threshold profile applied to the rule engines.
# One of: default | strict | lenient
VOICEIQ_THRESHOLD_PROFILE=default

# ---- API surface -----------------------------------------------------------
# Hard cap on incoming JSON payload size (KB) for /v1/insights/* and
# /v1/fact-check. Requests over this are rejected with 413 before the body
# is read into memory. Raise it only if your typical session payload is
# legitimately larger.
VOICEIQ_API_MAX_SESSION_PAYLOAD_KB=2048
# Hard cap on multipart upload size (MB) for /v1/process-audio. Enforced
# both via the Content-Length header and during streaming write. Raise it
# only if you process unusually long audio files.
VOICEIQ_API_MAX_UPLOAD_MB=200
# Wall-clock timeout (seconds) for the ffmpeg normalisation step. Default
# 120s gives long-form audio (60-minute meetings on a slow disk) room to
# finish; typical short clips complete in <5s. Trade-off:
#   * raise this if real audio trips the timeout (false 422s);
#   * lower it for tighter DoS protection against malformed input.
# A timeout surfaces as HTTP 422 (AUDIO_NORMALIZATION_TIMEOUT) — distinct
# from the 400 returned for malformed-codec failures.
VOICEIQ_FFMPEG_TIMEOUT_SEC=120.0

# ---- Authentication --------------------------------------------------------
# Comma-separated list of API keys accepted by the X-API-Key request header.
# Behaviour:
#   * 1+ keys configured: requests without a matching header are rejected
#     (401 missing / 403 invalid).
#   * Empty + non-production environment: auth is disabled with a warning so
#     local development against /docs / curl keeps working.
#   * Empty + production: the service refuses every request with 503 until
#     at least one key is set. Make sure to set this before deploying.
# Example: VOICEIQ_API_KEYS=local-dev-key,ci-key
VOICEIQ_API_KEYS=

# ---- Fact-Check source clients ---------------------------------------------
# OpenWeather (https://openweathermap.org/api). Free tier: 1000 calls/day.
# Empty value disables the WEATHER client (verdict becomes SOURCE_UNAVAILABLE).
VOICEIQ_OPENWEATHER_API_KEY=
# Alpha Vantage (https://www.alphavantage.co). Free tier: 25 calls/day.
# Empty value disables the STOCK_PRICE client.
VOICEIQ_ALPHAVANTAGE_API_KEY=
# Per-call HTTP timeout (seconds). Applies to all fact-check source clients.
VOICEIQ_FACTCHECK_HTTP_TIMEOUT_SEC=5.0

# ---- Agent Brain (Sprint 6) ------------------------------------------------
# Java Action Layer callback. Both URL and secret must be set to enable the
# callback; otherwise the Agent Brain only returns recommendations via its
# API and does not call out. The body is HMAC-SHA256 signed with the secret
# (X-VoiceIQ-Signature header); Java validates the signature.
VOICEIQ_AGENT_CALLBACK_URL=
VOICEIQ_AGENT_CALLBACK_SECRET=
# Outbound HTTP timeout (seconds) for the Java callback.
VOICEIQ_AGENT_CALLBACK_TIMEOUT_SEC=5.0
# Recommendations below this confidence are dropped before callback.
VOICEIQ_AGENT_MIN_CONFIDENCE=0.50
