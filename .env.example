# =============================================================================
# VoiceIQ Insight Service – environment configuration
# Copy this file to `.env` and edit the values you want to override.
# Every key is OPTIONAL: the service ships with safe defaults.
# Keys are read with the prefix VOICEIQ_  (handled by InsightSettings).
# =============================================================================

# ---- Service metadata -------------------------------------------------------
VOICEIQ_SERVICE_NAME="VoiceIQ Insight Service"
VOICEIQ_SERVICE_VERSION=1.0.0
# One of: development | staging | production | test
VOICEIQ_ENVIRONMENT=development
# One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
VOICEIQ_LOG_LEVEL=INFO

# ---- Persistence ------------------------------------------------------------
# SQLAlchemy URL. Defaults to a local SQLite file under ./data/insights.db.
# Examples:
#   sqlite:///./data/insights.db
#   sqlite:////absolute/path/insights.db
#   postgresql+psycopg://user:pass@localhost:5432/voiceiq
VOICEIQ_DATABASE_URL=sqlite:///./data/insights.db
# Set to true only for SQL debugging — very chatty.
VOICEIQ_DATABASE_ECHO=false
# Auto-create tables on startup. Disable in environments managed by migrations.
VOICEIQ_DATABASE_AUTO_CREATE=true

# ---- Engine configuration --------------------------------------------------
# Named threshold profile applied to the rule engines.
# One of: default | strict | lenient
VOICEIQ_THRESHOLD_PROFILE=default

# ---- API surface -----------------------------------------------------------
# Soft cap on incoming session payload size (KB).
VOICEIQ_API_MAX_SESSION_PAYLOAD_KB=2048
